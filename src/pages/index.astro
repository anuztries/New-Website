---
import BaseLayout from "../layouts/BaseLayout.astro";
import DrawingSheet from "../components/DrawingSheet.astro";
import SchematicPhoto from "../components/SchematicPhoto.astro";
import NetLabel from "../components/NetLabel.astro";
---

<BaseLayout>
  <DrawingSheet>
    <section class="hero-grid">
      <!-- LEFT: Bio Lines -->
      <div class="bio-section flex flex-col gap-6 max-w-xl">
        <h1 class="text-6xl text-blue-700">&lt; ANUJ KHATRI/&gt;</h1>

        <div class="hero-content">
          <p>&gt; Hello World!</p>

          <p>&gt; I am a wanna-be polymath.</p>

          <p>
            &gt; I build things with code, circuits, and whatever I can find.
          </p>
        </div>
      </div>

      <!-- CENTER: Schematic Photo -->
      <div class="photo-section flex justify-center items-start">
        <SchematicPhoto
          src="/profilepic.jpg"
          alt="Anuj Khatri"
          reference="P1"
          label="PERSON"
          value="ANUJ KHATRI"
          status="ALIVE"
          version="v20.0"
        />
      </div>

      <!-- RIGHT: Social Links -->
      <div class="socials-section flex flex-col gap-4">
        <p class="font-mono text-blue-700">user /socials</p>

        <div class="flex flex-col gap-4">
          <NetLabel label="GITHUB" href="https://github.com/yourusername" />

          <NetLabel
            label="LINKEDIN"
            href="https://linkedin.com/in/yourprofile"
          />

          <NetLabel
            label="INSTAGRAM"
            href="https://instagram.com/yourprofile"
          />

          <NetLabel label="RESUME" href="/resume.pdf" />
        </div>
      </div>
    </section>
  </DrawingSheet>
</BaseLayout>
